{
  "name": "ai-qa-agent",
  "version": "1.0.0",
  "description": "AI-powered QA agent using LangChain, AutoGen-style multi-agents, Playwright, and Claude",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r dotenv/config dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "qa": "ts-node -e \"require('dotenv').config(); require('./src/index.ts')\"",
    "clean": "rm -rf dist screenshots reports"
  },
  "keywords": ["qa", "testing", "playwright", "langchain", "anthropic", "ai-agent"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@langchain/anthropic": "^1.3.26",
    "@langchain/core": "^1.1.40",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "langchain": "^1.3.3",
    "playwright": "^1.59.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  }
}
